{
  "scripts": [
    { "src": "deploy/config.env",          "dst": "/opt/deploy-actions/config.env",          "mode": "644" },
    { "src": "deploy/install-dotnet.sh",   "dst": "/opt/deploy-actions/install-dotnet.sh",   "mode": "755" },
    { "src": "deploy/repos.txt",           "dst": "/opt/deploy-actions/repos.txt",           "mode": "644" },
    { "src": "deploy/setup-network.sh",    "dst": "/opt/deploy-actions/setup-network.sh",    "mode": "755" },
    { "src": "deploy/setup-ssh-keys.sh",   "dst": "/opt/deploy-actions/setup-ssh-keys.sh",   "mode": "755" },
    { "src": "deploy/clone-repos.sh",      "dst": "/opt/deploy-actions/clone-repos.sh",      "mode": "755" },
    { "src": "deploy/build.sh",            "dst": "/opt/deploy-actions/build.sh",            "mode": "755" },
    { "src": "deploy/setup-cluster-dir.sh","dst": "/opt/deploy-actions/setup-cluster-dir.sh","mode": "755" },
    { "src": "benchmark/memtier-bench.sh", "dst": "/usr/local/bin/memtier-bench",            "mode": "755" },
    { "src": "cluster/mcluster.sh",        "dst": "/usr/local/bin/mcluster",                 "mode": "755" },
    { "src": "cluster/simple-setup.ps1",   "dst": "/usr/local/bin/simple-setup.ps1",         "mode": "755" },
    { "src": "benchmark/memtier-bench.ps1","dst": "/usr/local/bin/memtier-bench.ps1",        "mode": "755" },
    { "src": "cluster/cluster-deploy.ps1", "dst": "/usr/local/bin/cluster-deploy.ps1",       "mode": "755" },
    { "src": "deploy/list-ips.ps1",        "dst": "/usr/local/bin/list-ips.ps1",              "mode": "755" }
  ],
  "runcmd": [
    { "run": "install-dotnet.sh",    "sudo": true,  "args": "" },
    { "run": "clone-repos.sh",       "sudo": false, "args": "" },
    { "run": "build.sh",             "sudo": true,  "args": "memtier" },
    { "run": "setup-network.sh",     "sudo": false, "args": "garnet" },
    { "run": "setup-ssh-keys.sh",    "sudo": false, "args": "", "background": true },
    { "run": "setup-cluster-dir.sh", "sudo": false, "args": "valkey" },
    { "run": "setup-cluster-dir.sh", "sudo": false, "args": "garnet" },
    { "run": "build.sh",             "sudo": true,  "args": "valkey 9.0" },
    { "run": "build.sh",             "sudo": true,  "args": "garnet" },
    { "run": "build.sh",             "sudo": true,  "args": "resp-bench vazois/cluster-bench" }
  ]
}
