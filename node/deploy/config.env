# Shared configuration for all deploy-actions scripts.
# Edit these values to change paths, ports, or settings globally.
# Repo paths are defined in manifest.json and read via jq.
DEPLOY_USER="guser"
USER_HOME="/home/guser"
IFACE="eth1"
BASE_PORT=7000
GARNET_PROJECT="main/GarnetServer"
RESP_BENCH_PROJECT="benchmark/Resp.benchmark"
RAMDISK_DIR="/mnt/ramdisk"
INSTALL_DIR="/usr/local/bin"
SSH_SECRET_NAME="vmss-ssh-private"
SUBNET="10.5.0.0/24"
VNET_PREFIX="10.5.0.0/16"
